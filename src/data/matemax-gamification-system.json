  "badge_rarity_config": {
    "common":    { "label": "Běžný",      "color": "#94a3b8", "border": "#64748b" },
    "uncommon":  { "label": "Neobvyklý",  "color": "#34d399", "border": "#059669" },
    "rare":      { "label": "Vzácný",     "color": "#60a5fa", "border": "#2563eb" },
    "epic":      { "label": "Epický",     "color": "#a78bfa", "border": "#7c3aed" },
    "legendary": { "label": "Legendární", "color": "#fbbf24", "border": "#d97706" }
  },

  "animation_types": {
    "pop": {
      "description": "Rychlé zvětšení a návrat na normální velikost",
      "css_keyframe": "scale(0) → scale(1.3) → scale(1)",
      "tailwind_classes": "animate-bounce"
    },
    "slide_up": {
      "description": "Element se vynoří odspodu",
      "css_keyframe": "translateY(40px) opacity(0) → translateY(0) opacity(1)"
    },
    "confetti": {
      "description": "Konfeti z několika míst po obrazovce",
      "library": "canvas-confetti",
      "config": { "particleCount": 100, "spread": 70, "origin": { "y": 0.6 } }
    },
    "fire_burst": {
      "description": "Animace plamene kolem ikony",
      "implementation": "Lottie JSON nebo CSS particle efekt"
    },
    "pulse_glow": {
      "description": "Opakující se záblesk barevné záře",
      "css_keyframe": "boxShadow 0px → 0 0 20px <color> → 0px"
    },
    "stars_explosion": {
      "description": "Hvězdičky vyletí z ikony do okolí",
      "implementation": "canvas-confetti se star shape"
    },
    "full_screen_confetti": {
      "description": "Konfeti přes celou obrazovku s více barvami",
      "library": "canvas-confetti",
      "config": { "particleCount": 300, "spread": 180, "startVelocity": 50 }
    },
    "level_up_burst": {
      "description": "Záblesk světla + level číslo se zvětší",
      "implementation": "CSS transition + canvas-confetti"
    },
    "lightning_flash": {
      "description": "Rychlý bílý záblesk + blesk ikona",
      "css_keyframe": "opacity(0) → opacity(1) → opacity(0), 200ms"
    },
    "diamond_sparkle": {
      "description": "Třpyt kolem diamantové ikony",
      "implementation": "Lottie nebo CSS pseudo-elements"
    }
  },

  "supabase_schema": {
    "tables": {
      "user_xp": {
        "columns": [
          { "name": "id", "type": "uuid", "primary": true },
          { "name": "user_id", "type": "uuid", "references": "auth.users.id" },
          { "name": "total_xp", "type": "integer", "default": 0 },
          { "name": "current_level", "type": "text", "default": "zacatecnik" },
          { "name": "updated_at", "type": "timestamptz" }
        ]
      },
      "xp_transactions": {
        "columns": [
          { "name": "id", "type": "uuid", "primary": true },
          { "name": "user_id", "type": "uuid", "references": "auth.users.id" },
          { "name": "xp_amount", "type": "integer" },
          { "name": "action", "type": "text" },
          { "name": "metadata", "type": "jsonb" },
          { "name": "created_at", "type": "timestamptz" }
        ]
      },
      "user_badges": {
        "columns": [
          { "name": "id", "type": "uuid", "primary": true },
          { "name": "user_id", "type": "uuid", "references": "auth.users.id" },
          { "name": "badge_id", "type": "text" },
          { "name": "earned_at", "type": "timestamptz" },
          { "name": "seen", "type": "boolean", "default": false }
        ],
        "unique_constraint": ["user_id", "badge_id"]
      }
    }
  },

